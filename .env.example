# GitHub auth (dev: GITHUB_TOKEN=$(gh auth token))
GITHUB_TOKEN=

# Repos to track: comma-separated "owner/name". Overrides projects.json if set.
REPOS=owner/repo-a,owner/repo-b

# GitHub team ("org/team") whose members appear on the board. Others show as guests.
ROSTER_TEAM=your-org/your-team

# SQLite path (mounted volume in Docker)
DB_PATH=/data/leaderboard.db

# Poll interval
POLL_INTERVAL=15m

# Health/dashboard port
HEALTH_PORT=8080

# Slack (phase 2 — unused in v1)
SLACK_BOT_TOKEN=
DIGEST_CHANNEL_ID=

# Hours a PR can wait for review before the digest flags it as stale
STALE_PR_HOURS=48

# Optional scoring overrides: PTS_BASE, PTS_CHANGES, PTS_COMMENTED, PTS_APPROVED,
# PTS_PER_INLINE, PTS_INLINE_CAP, PTS_SUBSTANCE, SUBSTANCE_CHARS
